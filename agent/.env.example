# =============================================================================
# Required API Keys
# =============================================================================
SERPER_API_KEY=xxx              # [Must have] Needed for serper search - https://serper.dev/
S2_API_KEY=xxx                  # Needed for snippet search - https://api.semanticscholar.org/
JINA_API_KEY=xxx                # Needed for jina-based browsing tool - https://jina.ai/reader/

# Optional: For using OpenAI models
OPENAI_API_KEY=

# =============================================================================
# Wandb (for training / RL experiments)
# =============================================================================
WANDB_API_KEY=                  # Weights & Biases API key
WANDB_ENTITY=                   # Wandb entity/team name
WANDB_PROJECT=rubric-rl        # Wandb project name

# =============================================================================
# Shenma API (Alibaba internal model serving)
# =============================================================================
SHENMA_API_KEY=                 # Shenma service authorization token
SHENMA_URL=                     # Shenma pre-release endpoint URL
SHENMA_URL_PROD=                # Shenma production endpoint URL

# =============================================================================
# Cloudsway Proxy API
# =============================================================================
CLOUDSWAY_API_KEY=              # Cloudsway API key/token

# Search & Reader URLs
CLOUDSWAY_SEARCH_URL=           # Cloudsway search endpoint (serp)
CLOUDSWAY_SCHOLAR_URL=          # Cloudsway scholar search endpoint
CLOUDSWAY_READER_URL=           # Cloudsway reader/browse endpoint

# LLM Proxy URLs
CLOUDSWAY_URL=                  # Default Cloudsway LLM endpoint
CLOUDSWAY_CLAUDE_URL=           # Cloudsway Claude proxy endpoint
CLOUDSWAY_GEMINI_PRO_URL=       # Cloudsway Gemini 2.5 Pro proxy endpoint
CLOUDSWAY_GEMINI_FLASH_URL=     # Cloudsway Gemini 2.5 Flash proxy endpoint
CLOUDSWAY_GPT5_URL=             # Cloudsway GPT-5 proxy endpoint
CLOUDSWAY_GPT4_MINI_URL=        # Cloudsway GPT-4.1-mini proxy endpoint
